# love_getVersion returns [major, minor, revision, codename].

fn check(cond, msg) { if (!cond) { error(msg); } }

fn run() {
    let v = love_getVersion();
    check(len(v) == 4, "version should have 4 fields");
    check(v[0] >= 0, "major should be a non-negative number");
    check(v[1] >= 0, "minor should be a non-negative number");
    check(v[2] >= 0, "revision should be a non-negative number");
    check(type(v[3]) == "string", "codename should be a string");
}

fn love_load() {
    run();
    println("CLOVE_TEST_OK");
    love_event_quit();
}

fn main() {}
