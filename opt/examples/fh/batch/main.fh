fn setSpriteBatch(self) {
    love_graphics_batch_clear(self.batch);
    for (let i = 0; i < self.count; i = i + 1) {

        love_graphics_batch_add(self.batch,
                math_random(0, love_window_getWidth()+100),
                math_random(0, love_window_getHeight()+100));
    }
    love_graphics_batch_flush(self.batch);
}

fn love_load()  {
    let self = {};
    self.count = 50000;

    self.image = love_graphics_newImage("../hey.png");
    self.batch = love_graphics_newSpriteBatch(self.image, self.count);
    setSpriteBatch(self);

    love_draw(self);
    love_update(1, self);
    return self;
}

fn love_update(dt, self) {
    setSpriteBatch(self);
}

fn love_draw(self) {
    love_graphics_draw(self.batch);
    love_graphics_print("" + love_timer_getFPS(), 10, 10);
}

